<!-- ─────────────── ARTISTS ─────────────── -->
<section id="artists">
  <p class="section-label">The Roster</p>
  <h2 class="section-title">Artists on the platform</h2>
  <p class="section-body">Early-to-mid career artists with strong technical execution, cultural grounding, and a clear community lens. Curated by hand.</p>

  <div class="artist-grid">
    <!-- Placeholder artist cards — replace with real artists -->
    <div class="artist-card">
      <div class="artist-avatar"><span>MP</span></div>
      <h3>Maple Perchlik</h3>
      <p>Burlington, VT</p>
      <p class="medium">Photography</p>
    </div>
