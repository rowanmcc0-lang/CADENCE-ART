<!-- ─────────────── NAV ─────────────── -->
<nav>
  <a class="nav-logo" href="#">Cadence</a>
  <ul class="nav-links">
    <li><a href="#about">About</a></li>
    <li><a href="#drop">Current Drop</a></li>
    <li><a href="#artists">Artists</a></li>
    <li><a href="#join">Join</a></li>
  </ul>
</nav>

<!-- ─────────────── HERO ─────────────── -->
<section id="hero">
  <div class="hero-content">
    <p class="hero-eyebrow">Vermont — Est. 2025</p>
    <h1 class="hero-title">
      Economic infrastructure<br>for <em>artists</em> who<br>make change.
    </h1>
    <p class="hero-sub">
      A cooperative-style art platform where early-career, justice-oriented artists get paid fairly — without the business headache. We handle the sales, shipping, and taxes. You keep making the work.
    </p>
    <div class="hero-cta">
      <a class="btn btn-primary" href="#drop">See the Current Drop</a>
      <a class="btn" href="#join">Apply as an Artist</a>
    </div>
  </div>
  <div class="hero-scroll">Scroll to explore</div>
</section>

<!-- ─────────────── ABOUT ─────────────── -->
<section id="about">
  <p class="section-label">What we are</p>
  <h2 class="section-title">Not a gallery. Not Etsy. Something built for artists first.</h2>
  <p class="section-body">
    We're a shared storefront, not a competitive marketplace. Artists here are selected, not just signed up. We treat your work with the seriousness it deserves — and build economic structures that actually work in your favor.
  </p>

  <div class="manifesto-grid">
    <div class="manifesto-item">
      <h3>No listing fees.<br>No pay-to-play.</h3>
      <p>You never pay to be visible here. Visibility is earned through quality, not advertising spend.</p>
    </div>
    <div class="manifesto-item">
      <h3>Transparent margins.</h3>
      <p>We show you exactly what we take and what you earn. No surprises. Artists know their numbers.</p>
    </div>
    <div class="manifesto-item">
      <h3>Human-made only.</h3>
      <p>No AI-generated work. Every piece on this platform was made by a person, in a community, with intention.</p>
    </div>
    <div class="manifesto-item">
      <h3>You own your work.</h3>
      <p>Full creative control, always. You have veto power over every decision about your art on this platform.</p>
    </div>
    <div class="manifesto-item">
      <h3>Local supply chains.</h3>
      <p>We partner with union and worker-owned print shops. Sustainable, regional, accountable.</p>
    </div>
    <div class="manifesto-item">
      <h3>Art for social change.</h3>
      <p>We specifically support artists with a community, justice, or political lens. This isn't incidental — it's the point.</p>
    </div>
  </div>
</section>

<!-- ─────────────── HOW IT WORKS ─────────────── -->
<section id="how-it-works">
  <p class="section-label">How it works</p>
  <h2 class="section-title">You make it. We sell it. You get paid.</h2>
  <p class="section-body">Simple enough to start now. Robust enough to build a real income from.</p>

  <div style="margin-top:3rem;">
    <p style="font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--mid);margin-bottom:1.5rem;">For artists</p>
    <div class="steps-grid">
      <div class="step">
        <p class="step-num">01</p>
        <h3>Apply & get selected</h3>
        <p>Tell us about your work and practice. We review every application by hand.</p>
      </div>
      <div class="step">
        <p class="step-num">02</p>
        <h3>We set you up</h3>
        <p>We handle pricing strategy, your artist profile, and all the technical listing work.</p>
      </div>
      <div class="step">
        <p class="step-num">03</p>
        <h3>Your work goes live</h3>
        <p>Either in a curated drop or the permanent storefront. We market it across all our channels.</p>
      </div>
      <div class="step">
        <p class="step-num">04</p>
        <h3>You get paid</h3>
        <p>Monthly payouts, one tax form at year end. We handle fulfillment, shipping, and customer service.</p>
      </div>
    </div>
  </div>

  <div style="margin-top:3rem;">
    <p style="font-size:0.72rem;letter-spacing:0.2em;text-transform:uppercase;color:var(--mid);margin-bottom:1.5rem;">For buyers</p>
    <div class="steps-grid">
      <div class="step">
        <p class="step-num">01</p>
        <h3>Discover curated work</h3>
        <p>Every artist here was selected. You're not wading through a sea of dropshipped prints.</p>
      </div>
      <div class="step">
        <p class="step-num">02</p>
        <h3>Know what you're buying</h3>
        <p>Artist profiles tell you who made it, where, and why. Full provenance, no mystery.</p>
      </div>
      <div class="step">
        <p class="step-num">03</p>
        <h3>Support something real</h3>
        <p>The majority of your purchase goes directly to the artist. We're transparent about what that split is.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─────────────── CURRENT DROP ─────────────── -->
