<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Cadence — Art for Social Change</title>
  <style>
    :root {
      --black: #0f0f0f;
      --white: #f5f2ed;
      --cream: #ede8df;
      --accent: #c8441a;
      --mid: #6b6560;
      --serif: 'Georgia', 'Times New Roman', serif;
      --sans: 'Helvetica Neue', 'Arial', sans-serif;
    }

    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      background: var(--white);
      color: var(--black);
      font-family: var(--sans);
      font-size: 16px;
      line-height: 1.6;
    }

    /* ── NAV ── */
    nav {
      position: fixed;
      top: 0; left: 0; right: 0;
      z-index: 100;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1.25rem 2rem;
      background: var(--white);
      border-bottom: 1px solid #ddd;
    }

    .nav-logo {
      font-family: var(--serif);
      font-size: 1.1rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
    }

    .nav-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .nav-links a {
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--black);
      text-decoration: none;
      transition: color 0.2s;
    }

    .nav-links a:hover { color: var(--accent); }

    /* ── HERO ── */
    #hero {
      min-height: 100vh;
      display: grid;
      grid-template-rows: 1fr auto;
      padding: 8rem 2rem 4rem;
      border-bottom: 1px solid #ddd;
    }

    .hero-content {
      display: flex;
      flex-direction: column;
      justify-content: center;
      max-width: 860px;
    }

    .hero-eyebrow {
      font-size: 0.72rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1.5rem;
    }

    .hero-title {
      font-family: var(--serif);
      font-size: clamp(2.8rem, 7vw, 5.5rem);
      line-height: 1.05;
      font-weight: normal;
      margin-bottom: 2rem;
    }

    .hero-title em {
      font-style: italic;
      color: var(--accent);
    }

    .hero-sub {
      font-size: 1rem;
      color: var(--mid);
      max-width: 520px;
      line-height: 1.7;
      margin-bottom: 2.5rem;
    }

    .hero-cta {
      display: flex;
      gap: 1rem;
      flex-wrap: wrap;
    }

    .btn {
      display: inline-block;
      padding: 0.85rem 2rem;
      font-size: 0.78rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      text-decoration: none;
      border: 1.5px solid var(--black);
      color: var(--black);
      transition: all 0.2s;
      cursor: pointer;
      background: transparent;
      font-family: var(--sans);
    }

    .btn:hover, .btn-primary {
      background: var(--black);
      color: var(--white);
    }

    .btn-primary:hover {
      background: var(--accent);
      border-color: var(--accent);
    }

    .hero-scroll {
      font-size: 0.7rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--mid);
      display: flex;
      align-items: center;
      gap: 0.5rem;
      padding-top: 2rem;
    }

    .hero-scroll::before {
      content: '';
      display: block;
      width: 40px;
      height: 1px;
      background: var(--mid);
    }

    /* ── SECTION SHARED ── */
    section {
      padding: 5rem 2rem;
      border-bottom: 1px solid #ddd;
    }

    .section-label {
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 3rem;
      display: flex;
      align-items: center;
      gap: 1rem;
    }

    .section-label::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #ddd;
      max-width: 80px;
    }

    .section-title {
      font-family: var(--serif);
      font-size: clamp(1.8rem, 4vw, 3rem);
      font-weight: normal;
      line-height: 1.2;
      max-width: 700px;
      margin-bottom: 1.5rem;
    }

    .section-body {
      color: var(--mid);
      max-width: 560px;
      line-height: 1.75;
      font-size: 0.97rem;
    }

    /* ── MANIFESTO / ABOUT ── */
    #about {
      background: var(--black);
      color: var(--white);
    }

    #about .section-label { color: var(--accent); }
    #about .section-label::after { background: #333; }
    #about .section-title { color: var(--white); }
    #about .section-body { color: #aaa; }

    .manifesto-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 2.5rem;
      margin-top: 3.5rem;
    }

    .manifesto-item {
      border-top: 1px solid #333;
      padding-top: 1.5rem;
    }

    .manifesto-item h3 {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: normal;
      margin-bottom: 0.75rem;
      color: var(--white);
    }

    .manifesto-item p {
      font-size: 0.88rem;
      color: #888;
      line-height: 1.7;
    }

    /* ── HOW IT WORKS ── */
    #how-it-works { background: var(--cream); }

    .steps-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .step {
      padding: 2rem 1.5rem;
      background: var(--white);
      border: 1px solid #ddd;
    }

    .step-num {
      font-size: 0.68rem;
      letter-spacing: 0.2em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .step h3 {
      font-family: var(--serif);
      font-size: 1.15rem;
      font-weight: normal;
      margin-bottom: 0.75rem;
    }

    .step p {
      font-size: 0.88rem;
      color: var(--mid);
      line-height: 1.7;
    }

    /* ── FEATURED DROP ── */
    #drop {
      background: var(--white);
    }

    .drop-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-end;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 3rem;
    }

    .drop-badge {
      display: inline-block;
      background: var(--accent);
      color: var(--white);
      font-size: 0.65rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      padding: 0.4rem 0.8rem;
      margin-bottom: 1rem;
    }

    .drop-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
      gap: 1.5px;
      background: #ddd;
    }

    .art-card {
      background: var(--white);
      position: relative;
      overflow: hidden;
      cursor: pointer;
    }

    .art-card-image {
      width: 100%;
      aspect-ratio: 4/5;
      background: var(--cream);
      display: flex;
      align-items: center;
      justify-content: center;
      overflow: hidden;
    }

    .art-card-image .placeholder-text {
      font-family: var(--serif);
      font-size: 0.85rem;
      color: var(--mid);
      letter-spacing: 0.05em;
      text-align: center;
      padding: 2rem;
      opacity: 0.5;
    }

    .art-card-info {
      padding: 1.25rem 1.25rem 1.5rem;
    }

    .art-card-artist {
      font-size: 0.7rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--mid);
      margin-bottom: 0.4rem;
    }

    .art-card-title {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: normal;
      margin-bottom: 0.5rem;
    }

    .art-card-price {
      font-size: 0.82rem;
      color: var(--mid);
    }

    .art-card-edition {
      font-size: 0.7rem;
      color: var(--accent);
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-top: 0.25rem;
    }

    /* ── ARTIST PROFILES ── */
    #artists { background: var(--cream); }

    .artist-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
      gap: 2rem;
      margin-top: 3rem;
    }

    .artist-card {
      text-decoration: none;
      color: var(--black);
    }

    .artist-avatar {
      width: 100%;
      aspect-ratio: 1;
      background: var(--mid);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .artist-avatar span {
      font-family: var(--serif);
      font-size: 1.5rem;
      color: var(--white);
      opacity: 0.5;
    }

    .artist-card h3 {
      font-family: var(--serif);
      font-size: 1rem;
      font-weight: normal;
      margin-bottom: 0.3rem;
    }

    .artist-card p {
      font-size: 0.78rem;
      color: var(--mid);
      margin-bottom: 0.25rem;
    }

    .artist-card .medium {
      font-size: 0.7rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--accent);
    }

    /* ── ECONOMICS (TRANSPARENCY) ── */
    #economics {
      background: var(--black);
      color: var(--white);
    }

    #economics .section-label { color: var(--accent); }
    #economics .section-label::after { background: #333; }
    #economics .section-title { color: var(--white); }

    .economics-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 1.5px;
      background: #222;
      margin-top: 3rem;
    }

    .econ-stat {
      background: var(--black);
      padding: 2.5rem 2rem;
    }

    .econ-number {
      font-family: var(--serif);
      font-size: 3rem;
      color: var(--accent);
      line-height: 1;
      margin-bottom: 0.75rem;
    }

    .econ-label {
      font-size: 0.78rem;
      color: #888;
      line-height: 1.5;
    }

    .economics-note {
      margin-top: 2.5rem;
      font-size: 0.85rem;
      color: #666;
      max-width: 560px;
      line-height: 1.7;
    }

    /* ── FOR ARTISTS CTA ── */
    #join {
      background: var(--cream);
    }

    .join-inner {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 4rem;
      align-items: center;
    }

    .join-form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
    }

    .join-form input, .join-form textarea, .join-form select {
      width: 100%;
      padding: 0.9rem 1rem;
      border: 1px solid #ccc;
      background: var(--white);
      font-family: var(--sans);
      font-size: 0.9rem;
      outline: none;
      appearance: none;
      color: var(--black);
    }

    .join-form input:focus, .join-form textarea:focus {
      border-color: var(--black);
    }

    .join-form textarea {
      height: 100px;
      resize: vertical;
    }

    .join-note {
      font-size: 0.75rem;
      color: var(--mid);
      margin-top: 0.5rem;
    }

    /* ── EMAIL SIGNUP ── */
    #notify {
      background: var(--accent);
      color: var(--white);
      padding: 4rem 2rem;
    }

    #notify .section-title {
      color: var(--white);
      margin-bottom: 0.75rem;
    }

    #notify .section-body {
      color: rgba(255,255,255,0.75);
      margin-bottom: 2rem;
    }

    .signup-row {
      display: flex;
      gap: 0;
      max-width: 480px;
    }

    .signup-row input {
      flex: 1;
      padding: 0.9rem 1rem;
      border: none;
      background: rgba(255,255,255,0.15);
      color: var(--white);
      font-family: var(--sans);
      font-size: 0.9rem;
      outline: none;
    }

    .signup-row input::placeholder { color: rgba(255,255,255,0.5); }

    .signup-row button {
      padding: 0.9rem 1.5rem;
      background: var(--black);
      color: var(--white);
      border: none;
      font-size: 0.75rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      cursor: pointer;
      font-family: var(--sans);
      white-space: nowrap;
    }

    /* ── FOOTER ── */
    footer {
      padding: 3rem 2rem;
      background: var(--black);
      color: #555;
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 1rem;
    }

    .footer-logo {
      font-family: var(--serif);
      font-size: 1rem;
      color: var(--white);
      letter-spacing: 0.08em;
    }

    .footer-links {
      display: flex;
      gap: 2rem;
      list-style: none;
    }

    .footer-links a {
      font-size: 0.75rem;
      color: #555;
      text-decoration: none;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }

    .footer-links a:hover { color: var(--white); }

    .footer-copy {
      font-size: 0.72rem;
      color: #444;
      width: 100%;
    }

    /* ── PILLARS ── */
    .pillars {
      display: flex;
      gap: 0;
      border: 1px solid #ddd;
      margin-top: 3rem;
      flex-wrap: wrap;
    }

    .pillar {
      flex: 1;
      min-width: 180px;
      padding: 2rem 1.5rem;
      border-right: 1px solid #ddd;
    }

    .pillar:last-child { border-right: none; }

    .pillar-icon {
      font-size: 0.7rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 1rem;
    }

    .pillar h3 {
      font-family: var(--serif);
      font-size: 1.1rem;
      font-weight: normal;
      margin-bottom: 0.75rem;
    }

    .pillar p {
      font-size: 0.83rem;
      color: var(--mid);
      line-height: 1.65;
    }

    /* ── RESPONSIVE ── */
    @media (max-width: 700px) {
      nav { padding: 1rem 1.25rem; }
      .nav-links { gap: 1rem; }
      section { padding: 4rem 1.25rem; }
      #hero { padding: 6rem 1.25rem 3rem; }
      .join-inner { grid-template-columns: 1fr; }
      .signup-row { flex-direction: column; }
      footer { flex-direction: column; }
    }
  </style>
</head>
